TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
TZ=UTC

# Host network identity. Set this to the server's static LAN address.
LAN_IP=192.168.1.10
ADGUARD_WEB_PORT=3001
GITEA_SSH_PORT=2222

# Dev (macOS): ./mock-usb
# Prod (Ubuntu Server): /mnt/usb-disk
BACKUP_DEST_PATH=./mock-usb

# Dev: mock-usb is a plain dir, so skip the mount guard.
BACKUP_REQUIRE_MOUNT=false
# Prod: enforce USB mount by setting BACKUP_REQUIRE_MOUNT=true on server.

# Encrypted, versioned restic backups. Generate a long value and keep it off
# the USB drive:
#   openssl rand -base64 48
RESTIC_PASSWORD=change-me-run-openssl-rand-base64-48
RESTIC_REPOSITORY=/backup/restic-repo
RESTIC_HOST=localcloud
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=6

# Domain standardization - single source of truth for Cloudflare
# Zero Trust Public Hostname routing (configured manually in dashboard).
BASE_DOMAIN=localcloud.example
MONITOR_SUBDOMAIN=monitor
GITEA_SUBDOMAIN=git
N8N_SUBDOMAIN=n8n
MATTERMOST_SUBDOMAIN=mattermost

# n8n credential encryption key. Generate once, back it up separately from
# the restic repository password, and never rotate casually:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# Optional Mattermost PostgreSQL password. Required only when enabling
# --profile chat. Generate a long random value
# with:  openssl rand -hex 32
# (use hex, NOT base64 - base64's + / = chars break the postgres:// connection
# string). Used by the mattermost + mattermost-postgres containers. The
# database is internal-only (no host port, no tunnel) - never exposed.
MATTERMOST_DB_PASSWORD=change-me-run-openssl-rand-hex-32

# Optional Podman API socket. Required only when enabling --profile mgmt
# for Portainer. Ubuntu Server rootless default:
PODMAN_SOCKET_PATH=/run/user/1000/podman/podman.sock
# macOS dev: replace with output of:
#   podman machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}'

# Optional image refs. Replace `latest` with version tags or digests before
# storing important data if you want fully reproducible upgrades.
CLOUDFLARED_IMAGE=docker.io/cloudflare/cloudflared:latest
PORTAINER_IMAGE=docker.io/portainer/portainer-ce:latest
GLANCES_IMAGE=docker.io/nicolargo/glances:latest
GITEA_IMAGE=docker.io/gitea/gitea:latest
N8N_IMAGE=docker.io/n8nio/n8n:latest
ADGUARD_IMAGE=docker.io/adguard/adguardhome:latest
