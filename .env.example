TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# Dev (macOS): ./mock-usb
# Prod (Debian): /mnt/usb-disk
BACKUP_DEST_PATH=./mock-usb

BACKUP_REQUIRE_MOUNT=false   # dev: mock-usb is a plain dir, skip guard
# BACKUP_REQUIRE_MOUNT=true  # prod: enforce USB mount — uncomment on server

# Domain standardization — single source of truth for Cloudflare
# Zero Trust Public Hostname routing (configured manually in dashboard).
BASE_DOMAIN=localcloud.example
PORTAINER_SUBDOMAIN=portainer
MONITOR_SUBDOMAIN=monitor
GITEA_SUBDOMAIN=git
N8N_SUBDOMAIN=n8n
MATTERMOST_SUBDOMAIN=mattermost

# Mattermost PostgreSQL password — gitignored. Generate a long random value
# with:  openssl rand -hex 32
# (use hex, NOT base64 — base64's + / = chars break the postgres:// connection
# string). Used by the mattermost + mattermost-postgres containers. The
# database is internal-only (no host port, no tunnel) — never exposed.
MATTERMOST_DB_PASSWORD=change-me-run-openssl-rand-hex-32

# Podman API socket — mounted into Portainer as /var/run/docker.sock
# Dev (macOS): output of `podman machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}'`
PODMAN_SOCKET_PATH=/var/folders/g4/sd497xns72n6vnpld82cp7j40000gn/T/podman/podman-machine-default-api.sock
# Prod (Debian rootless) — uncomment/set on server's .env instead:
# PODMAN_SOCKET_PATH=/run/user/1000/podman/podman.sock
